PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/ai_manga_reader
JWT_SECRET=replace-with-32-or-more-character-secret!!
CLIENT_URL=http://localhost:5173

# OpenAI (optional — without key, AI features return mock-safe output)
OPENAI_API_KEY=

# AWS S3 (optional — highest priority when bucket + keys + region are set)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
# Optional CDN / static site base for object URLs (no trailing slash)
AWS_S3_PUBLIC_BASE_URL=

# Cloudinary (optional — without credentials, images save under ./uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PREMIUM=

# Client (Vite)
VITE_API_URL=
